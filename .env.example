# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Shopify (via n8n webhook proxy)
SHOPIFY_PROXY_URL=https://maartenklouwen.app.n8n.cloud/webhook/cadomotus-shopify

# Gmail (via n8n webhook proxy — geen Google OAuth nodig)
N8N_REPORT_URL=https://maartenklouwen.app.n8n.cloud/webhook/cadomotus-seo-report
N8N_REPLIES_URL=https://maartenklouwen.app.n8n.cloud/webhook/cadomotus-seo-replies

# Google Search Console (optioneel — vereist OAuth token)
GOOGLE_SITE_URL=sc-domain:cadomotus.com

# Email ontvangers
REPORT_TO=diederik@cadomotus.com
REPORT_CC=maarten@thesystem.nl

# Agent
MODE=full

# === Optionele overrides (defaults zijn in agent.py) ===
# Sonnet 4.6 = goedkoopste keuze met goede output kwaliteit (~$2/run, $8/maand).
# Opus 4.7 als je de hoogste kwaliteit wil (~22× duurder, ~$44/run).
# Haiku 4.5 als je extreem zuinig wil (~$0.66/run) — kwaliteitsverlies mogelijk.
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=16000
CLAUDE_MAX_TURNS=30
PORT=8080

# === Shopify proxy auth (optioneel — als gezet stuurt Python bearer-header) ===
SHOPIFY_PROXY_SECRET=

# === Handmatige trigger van wekelijkse rapport via HTTP (optioneel)
# Als leeg: endpoint uit. Als gezet: GET /trigger?token=<TRIGGER_TOKEN> start het rapport.
TRIGGER_TOKEN=

# === Tijdzone (moet Europe/Amsterdam zijn — Python schedule werkt op lokale tijd) ===
TZ=Europe/Amsterdam

# === Dry-run + reports ===
# DRY_RUN=true voorkomt écht muteren — alleen payload wordt teruggegeven.
DRY_RUN=false
# REPORTS_DIR=/data/logs/reports

# === Reply-watcher poll ===
REPLY_POLL_INTERVAL=300

# === Reply thread webhook (n8n) ===
N8N_REPLY_THREAD_URL=https://maartenklouwen.app.n8n.cloud/webhook/cadomotus-seo-reply-thread

# === Google paths (defaults voor Easypanel volume mount) ===
GOOGLE_TOKEN_PATH=/data/token.json
GOOGLE_CREDENTIALS_PATH=/data/google_credentials.json

# === Google auth via env-var (zero-touch Easypanel setup) ===
# Eenmalig lokaal: python agent.py --auth → plak de inhoud van token.json
# HIER (op één regel). Bij startup wordt hij naar GOOGLE_TOKEN_PATH geschreven
# ALS die file nog niet bestaat. Daarna refresht de agent hem zelf op disk.
# GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"..."}
#
# Alleen nodig als je de OAuth-flow lokaal wilt kunnen herhalen op de server:
# GOOGLE_CREDENTIALS_JSON={"installed":{...}}
# Zonder token én zonder credentials werkt GSC niet, maar het rapport
# draait wél door op Shopify-data (grace fallback).
